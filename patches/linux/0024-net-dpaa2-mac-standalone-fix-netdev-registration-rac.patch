Fixes: f7f5b243f552 ("dpaa2-mac: probe standalone DPMAC objects")
Signed-off-by: Josua Mayer <josua@solid-run.com>
---
 .../freescale/dpaa2/dpaa2-mac-standalone.c    | 46 ++++++++++---------
 1 file changed, 24 insertions(+), 22 deletions(-)

diff --git a/drivers/net/ethernet/freescale/dpaa2/dpaa2-mac-standalone.c b/drivers/net/ethernet/freescale/dpaa2/dpaa2-mac-standalone.c
index 3e1aa29b43e7..8a12daf740c7 100644
--- a/drivers/net/ethernet/freescale/dpaa2/dpaa2-mac-standalone.c
+++ b/drivers/net/ethernet/freescale/dpaa2/dpaa2-mac-standalone.c
@@ -327,20 +327,6 @@ static int dpaa2_mac_probe(struct fsl_mc_device *mc_dev)
 
 	SET_NETDEV_DEV(net_dev, dev);
 
-#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
-	snprintf(net_dev->name, IFNAMSIZ, "mac%d", mc_dev->obj_desc.id);
-
-	/* register netdev just to make it visible to the user */
-	net_dev->netdev_ops = &dpaa2_mac_ndo_ops;
-	net_dev->ethtool_ops = &dpaa2_mac_ethtool_ops;
-
-	err = register_netdev(net_dev);
-	if (err) {
-		dev_err(dev, "register_netdev error %d\n", err);
-		goto free_netdev;
-	}
-#endif
-
 	dev_set_drvdata(dev, net_dev);
 
 	err = fsl_mc_portal_allocate(mc_dev, 0, &mc_dev->mc_io);
@@ -349,7 +335,7 @@ static int dpaa2_mac_probe(struct fsl_mc_device *mc_dev)
 			err = -EPROBE_DEFER;
 		else
 			dev_err(dev, "fsl_mc_portal_allocate err %d\n", err);
-		goto unregister_netdev;
+		goto free_netdev;
 	}
 	priv->mc_io = mc_dev->mc_io;
 
@@ -371,19 +357,34 @@ static int dpaa2_mac_probe(struct fsl_mc_device *mc_dev)
 		}
 	}
 
+#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
+	snprintf(net_dev->name, IFNAMSIZ, "mac%d", mc_dev->obj_desc.id);
+
+	/* register netdev just to make it visible to the user */
+	net_dev->netdev_ops = &dpaa2_mac_ndo_ops;
+	net_dev->ethtool_ops = &dpaa2_mac_ethtool_ops;
+
+	err = register_netdev(net_dev);
+	if (err) {
+		dev_err(dev, "register_netdev error %d\n", err);
+		goto disconnect_mac;
+	}
+#endif
+
 	return 0;
 
+#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
+disconnect_mac:
+	if (dpaa2_mac_is_type_phy(priv))
+		dpaa2_mac_disconnect(priv);
+#endif
 teardown_irqs:
 	dpaa2_mac_teardown_irqs(mc_dev);
 close_mac:
 	dpaa2_mac_close(priv);
 free_portal:
 	fsl_mc_portal_free(mc_dev->mc_io);
-unregister_netdev:
-#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
-	unregister_netdev(net_dev);
 free_netdev:
-#endif
 	free_netdev(net_dev);
 
 	return err;
@@ -395,6 +396,10 @@ static void dpaa2_mac_remove(struct fsl_mc_device *mc_dev)
 	struct net_device *net_dev = dev_get_drvdata(dev);
 	struct dpaa2_mac *priv = netdev_priv(net_dev);
 
+#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
+	unregister_netdev(net_dev);
+#endif
+
 	dpaa2_mac_teardown_irqs(mc_dev);
 
 	if (dpaa2_mac_is_type_phy(priv))
@@ -403,9 +408,6 @@ static void dpaa2_mac_remove(struct fsl_mc_device *mc_dev)
 
 	fsl_mc_portal_free(mc_dev->mc_io);
 	dev_set_drvdata(dev, NULL);
-#ifdef CONFIG_FSL_DPAA2_MAC_NETDEVS
-	unregister_netdev(net_dev);
-#endif
 	free_netdev(net_dev);
 }
 
