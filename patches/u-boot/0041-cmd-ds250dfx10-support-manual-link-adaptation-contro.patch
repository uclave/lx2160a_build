From bcd00b04e3b98dd18f85fb3904a7da77bdccfac2 Mon Sep 17 00:00:00 2001
From: Josua Mayer <josua@solid-run.com>
Date: Tue, 14 Apr 2026 17:26:48 +0200
Subject: [PATCH] cmd: ds250dfx10: support manual link adaptation control

Add new sub-commands:

- get/set adaptation mode
- reset cdr
- get/set dfe weights
- get/set eq boost

Signed-off-by: Josua Mayer <josua@solid-run.com>
---
 cmd/ds250dfx10.c | 557 +++++++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 543 insertions(+), 14 deletions(-)

diff --git a/cmd/ds250dfx10.c b/cmd/ds250dfx10.c
index ded3681bfbb..e0538b8a2cf 100644
--- a/cmd/ds250dfx10.c
+++ b/cmd/ds250dfx10.c
@@ -10,6 +10,7 @@
 #include <i2c.h>
 #include <linux/delay.h>
 #include <time.h>
+#include <stdint.h>
 
 enum ds250dfx10_reg_type {
 	DS250DFX10_REG_GLOBAL,
@@ -24,26 +25,54 @@ enum ds250dfx10_reg_type {
 #define DS250DFX10_CDR_LOCK_LOSS_INT		DS250DFX10_REG_CHANNEL,	0x01,	5,	1
 #define DS250DFX10_POL_INV_DET			DS250DFX10_REG_CHANNEL,	0x01,	6,	1
 #define DS250DFX10_PRBS_SEQ_DET			DS250DFX10_REG_CHANNEL,	0x01,	1,	4
